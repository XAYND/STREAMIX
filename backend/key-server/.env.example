PORT=3001

TOKEN_SECRET=change-me-with-a-long-random-secret
TOKEN_TTL_SECONDS=300

SESSION_JWT_SECRET=change-me-with-another-long-random-secret
SESSION_TTL_SECONDS=3600

ADMIN_LOGS_TOKEN=streamix-admin-logs

ALLOWED_ORIGINS=https://localhost:8443,http://localhost:8080,http://localhost:5173,http://localhost:3000

VIDEO_ID=streamix-demo

# Seeded into the local SQLite DB (data/streamix.db) on first boot so the
# app is usable without a manual /auth/register call.
DEMO_USER_EMAIL=demo@streamix.local
DEMO_USER_PASSWORD=StreamixDemo123!